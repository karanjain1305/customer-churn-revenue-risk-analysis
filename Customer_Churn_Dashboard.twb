      <aliases enabled='yes' />
      <column caption='Total Customers' datatype='integer' name='[Calculation_5688201305530368]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([customerID])' />
      </column>
      <column caption='Churned Customers' datatype='integer' name='[Calculation_5688201306546177]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Churn_Flag])' />
      </column>
      <column caption='Churn Rate' datatype='real' default-format='p0.00%' name='[Calculation_5688201306648578]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Churn_Flag]) / COUNTD([customerID])' />
      </column>
      <column caption='Monthly Revenue at Risk' datatype='real' default-format='C1033%' name='[Calculation_5688201306714115]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Monthly_Revenue_At_Risk])' />
      </column>
      <column caption='Average Monthly Charges' datatype='real' name='[Calculation_5688201306812420]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([MonthlyCharges])' />
      </column>
      <column caption='Churn Flag' datatype='integer' name='[Churn_Flag]' role='measure' type='quantitative' />
